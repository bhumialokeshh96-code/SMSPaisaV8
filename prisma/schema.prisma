generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum SmsStatus {
  QUEUED
  ASSIGNED
  SENT
  DELIVERED
  FAILED
}

enum LogStatus {
  SENT
  DELIVERED
  FAILED
}

enum TransactionType {
  EARNING
  WITHDRAWAL
  REFERRAL_BONUS
  SIGNUP_BONUS
  COMMISSION
  NEWBIE_REWARD
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  PROCESSING
}

enum TaskStatus {
  PENDING
  ASSIGNED
  CLAIMED
  IN_PROGRESS
  PROOF_UPLOADED
  VERIFIED
  COMPLETED
  FAILED
  EXPIRED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
}

enum UpiStatus {
  ACTIVE
  DISABLED
  FAILED
}

enum RiskLevel {
  NONE
  LOW
  MEDIUM
  HIGH
}

model User {
  id                  String    @id @default(uuid())
  phone               String    @unique
  name                String?
  email               String?
  referralCode        String    @unique
  referredById        String?
  referredBy          User?     @relation("UserReferrals", fields: [referredById], references: [id])
  referrals           User[]    @relation("UserReferrals")
  password            String?
  pin                 String?
  kycVerified         Boolean   @default(false)
  isActive            Boolean   @default(true)
  isSellActive        Boolean   @default(false)
  sellActivatedAt     DateTime?
  paymentAppInstalled Boolean   @default(false)
  totalCollection     Decimal   @default(0.00) @db.Decimal(12, 2)
  totalPayout         Decimal   @default(0.00) @db.Decimal(12, 2)
  role                Role      @default(USER)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  wallet              Wallet?
  devices             Device[]
  smsTasks            SmsTask[]         @relation("AssignedTasks")
  smsLogs             SmsLog[]
  transactions        Transaction[]
  referralsMade       Referral[]        @relation("ReferrerRelation")
  referralReceived    Referral?         @relation("ReferredRelation")
  paymentAccounts     PaymentAccount[]
  receivedSmsLogs     ReceivedSmsLog[]
  paymentTasks        PaymentTask[]     @relation("AssignedPaymentTasks")
  taskProofs          TaskProof[]
  userUpiAccounts     UserUpiAccount[]
  newbieReward        NewbieReward?
  withdrawals         Withdrawal[]
  notifications       Notification[]
}

model Wallet {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  balance        Decimal  @default(0.00) @db.Decimal(10, 2)
  reward         Decimal  @default(0.00) @db.Decimal(10, 2)
  pending        Decimal  @default(0.00) @db.Decimal(10, 2)
  totalEarned    Decimal  @default(0.00) @db.Decimal(10, 2)
  totalWithdrawn Decimal  @default(0.00) @db.Decimal(10, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SmsTask {
  id               String    @id @default(uuid())
  recipient        String
  message          String
  status           SmsStatus @default(QUEUED)
  assignedToId     String?
  assignedTo       User?     @relation("AssignedTasks", fields: [assignedToId], references: [id])
  assignedDeviceId String?
  assignedDevice   Device?   @relation(fields: [assignedDeviceId], references: [id])
  clientId         String
  priority         Int       @default(0)
  createdAt        DateTime  @default(now())
  assignedAt       DateTime?
  sentAt           DateTime?
  deliveredAt      DateTime?

  smsLogs SmsLog[]
}

model SmsLog {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  taskId       String
  task         SmsTask   @relation(fields: [taskId], references: [id])
  status       LogStatus
  amountEarned Decimal   @default(0.00) @db.Decimal(10, 2)
  sentAt       DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime  @default(now())

  @@unique([taskId, status])
}

model Transaction {
  id               String            @id @default(uuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id])
  type             TransactionType
  amount           Decimal           @db.Decimal(10, 2)
  status           TransactionStatus @default(PENDING)
  paymentMethod    String?
  paymentDetails   Json?
  razorpayPayoutId String?
  relatedTaskId    String?
  description      String?
  createdAt        DateTime          @default(now())
}

model Device {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  deviceName       String
  deviceId         String    @unique
  simInfo          Json?
  dailyLimit       Int       @default(300)
  activeHoursStart String    @default("09:00")
  activeHoursEnd   String    @default("21:00")
  isOnline         Boolean   @default(false)
  lastSeen         DateTime?
  smsSentToday     Int       @default(0)
  createdAt        DateTime  @default(now())

  smsTasks         SmsTask[]
  receivedSmsLogs  ReceivedSmsLog[]
}

model ReceivedSmsLog {
  id         String   @id @default(uuid())
  userId     String
  deviceId   String
  sender     String
  message    String
  simSlot    Int      @default(0)
  receivedAt DateTime
  createdAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  device Device @relation(fields: [deviceId], references: [id])

  @@unique([userId, sender, receivedAt])
  @@index([receivedAt])
  @@index([userId])
  @@index([sender])
}

model Referral {
  id             String   @id @default(uuid())
  referrerId     String
  referrer       User     @relation("ReferrerRelation", fields: [referrerId], references: [id])
  referredId     String   @unique
  referred       User     @relation("ReferredRelation", fields: [referredId], references: [id])
  level          String   @default("B")
  commissionRate Decimal  @default(0.00) @db.Decimal(5, 2)
  bonusPaid      Boolean  @default(false)
  referrerBonus  Decimal  @default(10.00) @db.Decimal(10, 2)
  referredBonus  Decimal  @default(5.00)  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())
}

model PlatformSettings {
  id                       String   @id @default("default")
  perRoundSendLimit        Int      @default(25)
  defaultCommissionRate    Decimal  @default(4.5) @db.Decimal(5, 2)
  minWithdrawalAmount      Decimal  @default(50.00) @db.Decimal(10, 2)
  maxWithdrawalPerDay      Decimal  @default(10000.00) @db.Decimal(10, 2)
  newbieRewardAmount       Decimal  @default(350.00) @db.Decimal(10, 2)
  newbieRewardThreshold    Decimal  @default(2000.00) @db.Decimal(12, 2)
  signupBonus              Decimal  @default(0.00) @db.Decimal(10, 2)
  referrerBonus            Decimal  @default(10.00) @db.Decimal(10, 2)
  referredBonus            Decimal  @default(5.00) @db.Decimal(10, 2)
  cashbackDisplayRate      Decimal  @default(4.5) @db.Decimal(5, 2)
  paymentWarningMessage    String   @default("Please use Freecharge or Mobikwik or amazon wallet for payment!")
  updatedAt                DateTime @updatedAt
}

model PaymentAccount {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  type              String
  upiId             String?
  accountNumber     String?
  ifsc              String?
  bankName          String?
  accountHolderName String?
  details           String
  isDefault         Boolean  @default(false)
  createdAt         DateTime @default(now())
}

model AppVersion {
  id            String   @id @default("current")
  latestVersion String
  minVersion    String
  apkUrl        String
  releaseNotes  String   @default("")
  forceUpdate   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PaymentTask {
  id               String     @id @default(uuid())
  // code must be exactly 6 alphanumeric characters — enforced by @db.Char(6) and generated by generateTaskCode() in helpers.js
  code             String     @unique @db.Char(6)
  title            String?
  amount           Decimal    @db.Decimal(12, 2)
  commissionRate   Decimal    @default(4.5) @db.Decimal(5, 2)
  commissionAmount Decimal    @db.Decimal(12, 2)
  recipientName    String?
  recipientUPI     String
  paymentMethod    String     @default("UPI")
  instructions     String?
  status           TaskStatus @default(PENDING)
  assignedToId     String?
  assignedTo       User?      @relation("AssignedPaymentTasks", fields: [assignedToId], references: [id])
  claimedAt        DateTime?
  completedAt      DateTime?
  expiresAt        DateTime?
  priority         Int        @default(0)
  createdAt        DateTime   @default(now())

  proofs TaskProof[]
}

model TaskProof {
  id            String      @id @default(uuid())
  taskId        String
  task          PaymentTask @relation(fields: [taskId], references: [id])
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  screenshotUrl String?
  transactionId String?
  notes         String?
  isVerified    Boolean     @default(false)
  verifiedAt    DateTime?
  verifiedBy    String?
  createdAt     DateTime    @default(now())
}

model UserUpiAccount {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  upiType        String    @default("UPI")
  upiId          String
  status         UpiStatus @default(ACTIVE)
  riskLevel      RiskLevel @default(NONE)
  limitMin       Decimal   @default(10.00) @db.Decimal(12, 2)
  limitMax       Decimal   @default(100000.00) @db.Decimal(12, 2)
  paymentAppName String?
  isDefault      Boolean   @default(false)
  createdAt      DateTime  @default(now())
}

model NewbieReward {
  id                        String   @id @default(uuid())
  userId                    String   @unique
  user                      User     @relation(fields: [userId], references: [id])
  amount                    Decimal  @default(350.00) @db.Decimal(10, 2)
  totalTransactionsRequired Decimal  @default(2000.00) @db.Decimal(12, 2)
  currentTransactionTotal   Decimal  @default(0.00) @db.Decimal(12, 2)
  isClaimed                 Boolean  @default(false)
  claimedAt                 DateTime?
  createdAt                 DateTime @default(now())
}

model Withdrawal {
  id               String           @id @default(uuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id])
  amount           Decimal          @db.Decimal(10, 2)
  status           WithdrawalStatus @default(PENDING)
  paymentMethod    String
  paymentDetails   Json
  pinVerified      Boolean          @default(false)
  razorpayPayoutId String?
  processedAt      DateTime?
  rejectionReason  String?
  createdAt        DateTime         @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
